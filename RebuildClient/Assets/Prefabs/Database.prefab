      m_Calls: []
  m_text: "syntax: <b>#key<noparse><op></noparse>value</b>   (free text also matches
    id / name / code)\n\n<b>operators:</b>\n=\n!=\n<noparse><</noparse>\n<noparse><=</noparse>\n<noparse>></noparse>\n<noparse>>=</noparse>\n\n<b>monsters:</b>\nid\nlevel
    (lvl)\nhp\nexp (bexp)\njexp (jobexp)\natk (atkmin), atkmax\ndef, mdef\nstr, agi,
    vit, int, dex, luk\nrange\ncode, name\nsize\nelement (elem)\nrace\ntag (tags)\n\n<b>items:</b>\nid\ncode,
    name\ndescription (desc)\nslot (slots)\nprice (buy), sell (sellprice)\nrefinable\ntype
    (class, itemclass)\n - useable\n - weapon\n - equipment\n - ammo\n - card\n -
    etc\nuse (usetype)\n - notusable\n - use\n - useonally\n - useonenemy\npos (position)\n
    - headupper, headmid, headlower (or: headgear)\n - mainhand (or: weapon)\n -
    offhand (or: shield)\n - bothhands (or: anyhand)\n - body (or: armor)\n - garment\n
    - footgear (or: boots)\n - accessory\nweapon (weaponclass)\nammo (ammotype)\n\n<b>maps:</b>\ncode\nname"
  m_isRightToLeft: 0
