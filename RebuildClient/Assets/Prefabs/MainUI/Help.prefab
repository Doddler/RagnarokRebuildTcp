  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<b>Tips</b>\r\n- The bard south of prontera can change your jobs, reset
    your skills, and change your appearance.\r\n- Chats can be heard by all players
    on the map. Use /shout to be heard server-wide.\n- Pressing spacebar can be used
    to stop any action such as attacking or moving.\r\n\n<b>Shortcut Keys</b>\nQ
    - Equipment Window\r\nE - Inventory\r\nW - Cart Inventory\r\nA - Stat Window\r\nS
    - Skill Window\r\nD - Emote Window\r\nF12 - Hotbar\n\r\n<b>Useful Text Commands</b>\r\n/shout
    -- Sends a message to all players (please be respectful)\n/info -- Shows population
    and server uptime\n/where  -- Shows your current location in chat\r\n/bgm  --
    Toggle background music\r"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: f526b3b4777a17244865df0c27c65fbf, type: 2}
